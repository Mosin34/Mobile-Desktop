name: Translate

on:
  workflow_dispatch: # Esto activa el botón para ejecutarlo manualmente desde la web

jobs:
  translate:
    runs-on: ubuntu-latest

    steps:
      # 1. Descargar el código del repositorio
      - name: Checkout code
        uses: actions/checkout@v4

      # 2. Configurar el entorno de Flutter en el servidor de GitHub
      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'

      # 3. Descargar las dependencias del proyecto de Moonfin
      - name: Install dependencies
        run: flutter pub get

      # 4. Activar e invocar arb_translate usando tu clave secreta de Gemini
      - name: Run arb_translate
        env:
          ARB_TRANSLATE_API_KEY: ${{ secrets.ARB_TRANSLATE_API_KEY }}
        run: |
          flutter pub global activate arb_translate
          flutter pub global run arb_translate

      # 5. Guardar los cambios automáticamente en tu repositorio
      - name: Commit and push changes
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "Traducciones automáticas generadas por IA"
          branch: ${{ github.ref }}
